{
  "name": "formelio",
  "version": "0.2.0",
  "description": "Forms for humans",
  "author": "Sergio Garcia Mondaray <sgmonda@gmail.com> (https://sgmonda.com)",
  "license": "MIT",
  "repository": "Sergio Garcia Mondaray <sgmonda@gmail.com> (https://github.com/sgmonda/formelio/)",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./styles.css": "./dist/index.css",
    "./dist/index.css": "./dist/index.css"
  },
  "sideEffects": [
    "*.css",
    "*.sass"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "clean": "rm -Rf dist/* site/build/*",
    "build": "tsup",
    "lint": "eslint --fix -c .eslintrc . --ext .tsx,.ts --ignore-path .eslintignore",
    "dev": "tsup --watch",
    "dev:site": "npm run build && cd site && npm install && npm run dev",
    "dev:test": "vitest",
    "prepare": "husky",
    "test": "npm run lint && npm run test:unit",
    "test:unit": "vitest run",
    "test:unit:reset": "vitest run --update",
    "predeploy": "cd site && npm install && npm run build",
    "site": "npm run site:build && npm run site:deploy",
    "site:build": "cd site && npm install && npm run build",
    "site:deploy": "gh-pages -d site/dist",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "styled-components": "^5.2.1 || ^6.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.0",
    "@commitlint/config-conventional": "^19.6.0",
    "@storybook/addon-essentials": "^8.4.0",
    "@storybook/addon-links": "^8.4.0",
    "@storybook/react": "^8.4.0",
    "@storybook/react-vite": "^8.4.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/styled-components": "^5.1.9",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "classnames": "^2.5.0",
    "esbuild-sass-plugin": "^3.6.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-prettier": "^5.2.0",
    "eslint-plugin-react": "^7.37.0",
    "gh-pages": "^2.2.0",
    "husky": "^9.1.0",
    "jsdom": "^25.0.0",
    "lint-staged": "^15.3.0",
    "prettier": "^3.4.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "sass": "^1.80.0",
    "storybook": "^8.4.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vite": "^6.4.1",
    "vitest": "^3.2.4"
  },
  "files": [
    "dist"
  ],
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,html,css,scss,md}": [
      "prettier --write --config .prettierrc"
    ],
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix -c .eslintrc"
    ]
  },
  "dependencies": {
    "@popperjs/core": "^2.9.2",
    "date-fns": "^4.1.0",
    "react-datepicker": "^7.5.0",
    "react-select": "^5.8.0"
  }
}
